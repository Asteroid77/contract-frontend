{
  "name": "contract-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix && pnpm check:px",
    "check:px": "node ./scripts/check-px-whitelist.mjs",
    "check:unwrap": "node ./scripts/check-unwrap-allowlist.mjs",
    "format": "prettier --write src/",
    "release": "standard-version",
    "backup": "git add . && git commit -m \"wip: temp backup $(date +%Y-%m-%d_%H:%M:%S)\" && git push nutstore HEAD:backup-branch --force && git reset HEAD~1",
    "theme:gen": "ts-node --esm ./scripts/GenerateTheme.ts"
  },
  "dependencies": {
    "@ant-design/colors": "^7.2.1",
    "@casl/ability": "^6.8.0",
    "@casl/vue": "^2.2.6",
    "@openreplay/tracker": "^17.1.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^2.5.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/instrumentation": "^0.211.0",
    "@opentelemetry/instrumentation-document-load": "^0.56.0",
    "@opentelemetry/instrumentation-fetch": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-trace-web": "^2.5.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/query-core": "^5.90.5",
    "@tanstack/query-persist-client-core": "^5.91.4",
    "@tanstack/query-sync-storage-persister": "^5.90.7",
    "@tanstack/vue-query": "^5.90.5",
    "@tanstack/vue-query-devtools": "^5.90.5",
    "@types/qs": "^6.14.0",
    "@vicons/antd": "^0.13.0",
    "@vicons/fluent": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vue/runtime-core": "3.5.20",
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.6",
    "axios-mock-adapter": "^2.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "dexie": "^4.2.0",
    "echarts": "^6.0.0",
    "lodash": "^4.17.23",
    "md-editor-v3": "^6.3.1",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.3",
    "print-js": "^1.6.0",
    "qs": "^6.15.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "ts-pattern": "^5.8.0",
    "vue": "^3.5.20",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.1.11",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.18.0",
    "@vicons/carbon": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vitest/eslint-plugin": "^1.3.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "async-validator": "^4.2.5",
    "eslint": "^9.34.0",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-vue": "~10.3.0",
    "jiti": "^2.5.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "seemly": "^0.3.10",
    "standard-version": "^9.5.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.1",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.6"
  }
}
