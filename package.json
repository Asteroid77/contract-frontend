    "clsx": "^2.1.1",
    "dexie": "^4.2.0",
    "pinia": "^3.0.3",
    "tailwindcss": "^4.1.12",
    "ts-pattern": "^5.8.0",
    "vue": "^3.5.20",
    "vue-i18n": "^11.1.11",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
